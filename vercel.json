{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/briefing-generate.ts": { "maxDuration": 60 },
    "api/briefing-cron.ts": { "maxDuration": 300 },
    "api/tasks-classify.ts": { "maxDuration": 30 },
    "api/coach-chat.ts": { "maxDuration": 60 },
    "api/coach-memory-extract.ts": { "maxDuration": 30 },
    "api/coach-checkin-cron.ts": { "maxDuration": 300 },
    "api/special-dates-cron.ts": { "maxDuration": 300 },
    "api/rituals-cron.ts": { "maxDuration": 300 },
    "api/contacts-suggest-message.ts": { "maxDuration": 30 },
    "api/tasks-sync.ts": { "maxDuration": 300 },
    "api/events-sync.ts": { "maxDuration": 300 },
    "api/contacts-sync.ts": { "maxDuration": 300 },
    "api/hill-coach-chat.ts": { "maxDuration": 60 },
    "api/hill-coach-wizard-step.ts": { "maxDuration": 30 },
    "api/hill-coach-murmur.ts": { "maxDuration": 30 },
    "api/hill-cron-daily-nudge.ts": { "maxDuration": 300 },
    "api/hill-mastermind-session.ts": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/briefing-cron",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/coach-checkin-cron",
      "schedule": "0,30 * * * *"
    },
    {
      "path": "/api/special-dates-cron",
      "schedule": "0,30 * * * *"
    },
    {
      "path": "/api/rituals-cron",
      "schedule": "0,30 * * * *"
    },
    {
      "path": "/api/hill-cron-daily-nudge",
      "schedule": "30 7 * * *"
    }
  ]
}
