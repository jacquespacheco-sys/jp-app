# =============================================================
# JP APP — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# NUNCA commite .env.local no git
# =============================================================

# Auth
JWT_SECRET=                        # gerar: openssl rand -hex 32
ENCRYPTION_KEY=                    # AES-256, 32 bytes hex: openssl rand -hex 32

# Supabase
SUPABASE_URL=                      # https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=              # service_role key (backend only)
SUPABASE_ANON_KEY=                 # anon key (frontend via VITE_)

# Exposta ao frontend (prefixo VITE_ obrigatório para Vite)
VITE_SUPABASE_URL=                 # mesmo que SUPABASE_URL
VITE_SUPABASE_ANON_KEY=            # mesmo que SUPABASE_ANON_KEY

# Anthropic
ANTHROPIC_API_KEY=                 # sk-ant-...

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=               # https://jpapp.jorge.com/api/google-oauth?action=callback

# Resend (email)
RESEND_API_KEY=                    # re_...
RESEND_FROM_EMAIL=                 # briefing@jpapp.jorge.com

# IMAP (newsletters)
IMAP_HOST=                         # imap.gmail.com
IMAP_USER=                         # email dedicado para newsletters
IMAP_PASSWORD=                     # app password (não a senha normal)

# Cron
CRON_SECRET=                       # bearer token: openssl rand -hex 32

# App
APP_URL=                           # https://jpapp.jorge.com
